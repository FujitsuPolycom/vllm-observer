# ---------------------------------------------------------------------------
# vLLM Observer — environment variable template
#
# Copy this file to .env (same directory as docker-compose.yml) and edit
# values as needed:
#     cp .env.example .env
#
# All variables are optional; the defaults shown below work for the most
# common deployment: observer + vLLM on the same Linux Docker host.
# ---------------------------------------------------------------------------

# --- Networking -----------------------------------------------------------

# Host the observer contacts to reach vLLM Prometheus /metrics endpoints.
# In Docker Compose with extra_hosts, host.docker.internal resolves to the
# Docker host gateway.  For direct `docker run` on Linux without extra_hosts,
# use the host IP or 172.17.0.1 (default Docker bridge gateway).
# Default in compose:  host.docker.internal
# Default in collector.py (no compose):  127.0.0.1  (host-network mode)
#VLLM_OBSERVER_METRICS_HOST=host.docker.internal

# Explicit single Prometheus metrics URL.  Overrides auto-discovery by port.
# Example: VLLM_OBSERVER_METRICS_URL=http://host.docker.internal:8000/metrics
#VLLM_OBSERVER_METRICS_URL=

# Per-container metrics URL.  Replace punctuation in the container name with
# underscores and uppercase.  Example for container "my-vllm":
#VLLM_OBSERVER_METRICS_URL_MY_VLLM=http://host.docker.internal:8000/metrics

# HTTP listen address and port for the observer dashboard/API.
#VLLM_OBSERVER_HOST=0.0.0.0
#VLLM_OBSERVER_PORT=8088

# --- Docker discovery -----------------------------------------------------

# Enable Docker container discovery (1) or disable it (0).
#VLLM_OBSERVER_DOCKER=1

# Comma-separated terms to match container names, images, commands, and
# label keys.  If set, these REPLACE the built-in defaults.  Built-in terms:
#   vllm, sglang, triton, serve-glm, glm52, deepseek, llama-server
# (lmcache is excluded by default because LMCache server containers have no
# Prometheus /metrics endpoint and would show as errors.)
#VLLM_OBSERVER_DISCOVERY_TERMS=

# Exact container names to observe (comma-separated).  If set, only these
# containers are considered; all others are ignored.
#VLLM_OBSERVER_CONTAINER_ALLOWLIST=

# Comma-separated log file paths or directories (for file-based mode).
#VLLM_OBSERVER_LOG_PATHS=

# --- Sampling -------------------------------------------------------------

# Real server-side metric sample interval in seconds.
#VLLM_OBSERVER_SAMPLE_SECONDS=1

# Number of real samples retained per workload in rolling history.
#VLLM_OBSERVER_HISTORY_POINTS=3600

# --- Log archive ----------------------------------------------------------

# Maximum lines returned per workload log fetch.
#VLLM_OBSERVER_LOG_TAIL=320

# Interval for capturing new log lines into the archive (seconds).
#VLLM_OBSERVER_LOG_SAMPLE_SECONDS=3

# Maximum age of retained log archive entries (seconds).  Default: 7 days.
#VLLM_OBSERVER_LOG_HISTORY_SECONDS=604800

# Log archive window returned around a selected chart point (seconds).
#VLLM_OBSERVER_LOG_CONTEXT_SECONDS=30

# Maximum lines returned for selected log context.
#VLLM_OBSERVER_LOG_CONTEXT_LINES=1000

# Maximum persisted log archive size in bytes.  Default: 50 MB.
#VLLM_OBSERVER_LOG_HISTORY_MAX_BYTES=50000000

# --- Analytics ------------------------------------------------------------

# Long-term Request Analytics snapshot interval (seconds).
#VLLM_OBSERVER_ANALYTICS_SAMPLE_SECONDS=60

# Long-term Request Analytics retention age (seconds).  Default: 7 days.
#VLLM_OBSERVER_ANALYTICS_HISTORY_SECONDS=604800

# --- Persistence ----------------------------------------------------------

# Directory for durable rolling history.  In Compose this is set to /data
# on a named volume.  Leave empty for in-memory only (no persistence).
#VLLM_OBSERVER_DATA_DIR=/data

# Enable access log output to stdout (1) or suppress it (0).
#VLLM_OBSERVER_ACCESS_LOG=0
